   "source": [
    "from pathlib import Path\n",
    "\n",
    "name = \"noext-binary\"\n",
    "original = bytes([0xFF, 0xFE, 0xFD, 0x80, 0x61])\n",
    "\n",
    "p = Path(name)\n",
    "p.write_bytes(original)\n",
    "\n",
    "roundtrip = Path(name).read_bytes()\n",
    "\n",
    "if original.hex() == roundtrip.hex():\n",
    "    print(\"file-access-5 done\")"
   ]
  }
 ],
