{
  "LiteBuildConfig": {
    "contents": ["."],
    "output_dir": "../build/docs-app"
  },
  "PyodideLockAddon": {
    "enabled": true,
    "specs": ["--group ..:demo"],
    "prefetch_extra": ["ipywidgets"],
    "pyodide_lock_uv_options": {
      "preserve_url_prefixes": ["https://"]
    },
    "lite_constraints_file": "requirements-pyodide-lock.txt",
    "excludes": [
      "psutil"
    ],
    "patches": {
      "packages": {
        "plotly": {
          "depends": ["tenacity", "packaging", "nbformat"]
        },
        "ipywidgets": {
          "depends": ["comm", "ipython", "traitlets"]
        }
      }
    }
  }
}
